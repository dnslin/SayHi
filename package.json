{
  "name": "sayhi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22.17.0",
    "npm": ">=10.9.2"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "npm run test:contracts && npm run test:knowledge",
    "test:contracts": "npm run build && node --test packages/testing/dist/core.contract.test.js packages/testing/dist/dependency-graph.contract.test.js packages/testing/dist/workflow.contract.test.js packages/testing/dist/task-lifecycle.contract.test.js packages/testing/dist/task-lifecycle-filesystem.contract.test.js packages/testing/dist/initiative-graph-record.contract.test.js packages/testing/dist/initiative-scheduler.contract.test.js packages/testing/dist/execution.contract.test.js packages/testing/dist/record-contracts.contract.test.js packages/testing/dist/managed-project.contract.test.js packages/testing/dist/cli.contract.test.js packages/testing/dist/managed-project-cli.contract.test.js packages/testing/dist/managed-project-bin.contract.test.js packages/testing/dist/omp.contract.test.js packages/testing/dist/milestone-zero.contract.test.js packages/testing/dist/milestone-zero-domain.contract.test.js packages/testing/dist/milestone-zero-provenance.contract.test.js packages/testing/dist/milestone-zero-security.contract.test.js packages/testing/dist/context-manifest.contract.test.js packages/testing/dist/spec-context-cli.contract.test.js packages/testing/dist/context-cli.contract.test.js",
    "test:milestone-2": "npm run test:contracts",
    "test:knowledge": "npm run build && node --test packages/testing/dist/knowledge.contract.test.js",
    "typecheck": "tsc --project tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2"
  }
}
